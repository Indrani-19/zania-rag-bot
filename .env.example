OPENAI_API_KEY=sk-replace-me

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: route through any OpenAI-compatible provider (e.g. Ollama for local dev).
# When unset, hits api.openai.com.
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2:1b
# EMBEDDING_MODEL=nomic-embed-text

# Cloud Llama via Groq (free tier — see DEPLOY.md). Groq has no embedding API,
# so flip embeddings to local sentence-transformers in the same step.
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Index samples/spec_kb.json under document_id "demo-spec-kb" at startup so
# first-time visitors to the chat UI can ask questions without uploading.
# DEMO_PRELOAD=true

CHROMA_PERSIST_DIR=./chroma_db
RETRIEVAL_TOP_K=4
SIMILARITY_FLOOR=0.5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

MAX_UPLOAD_SIZE_MB=50
COST_HARD_CAP_USD=4.0
LOG_LEVEL=INFO
LLM_TIMEOUT_S=30
